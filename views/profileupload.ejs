<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <h3 class="text=3xl mb-5">Upload profile picture</h3>
      <form action="/fileUpload" method="post" enctype="multipart/form-data">
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md"
          type="file"
          placeholder="file"
          name="image"
        />
        <input
          class="px-3 py-2 outline-none bg-blue-600 border-2 border-zinc-500 rounded-md"
          type="submit"
          value="Upload File"
        />
      </form>
    </div>
  </body>
</html>
