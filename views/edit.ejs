<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <div class="w-full flex justify-end">
        <a
          href="/logout"
          class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block"
          >Logout</a
        >
      </div>
      <h3 class="text=3xl mb-5">
        <span class="font-light">Hello</span>, <%= post.user.name %>👋
      </h3>
      <h5 class="mb-5">Edit post.</h5>
      <form method="post" action="/update">
        <textarea
          name="content"
          placeholder="what's on your mind ?"
          class="p-3 outline-none w-1/3 resize-none block bg-tansparent border-2 border-zinc-800 rounded-md"
        >
<%=post.content%></textarea
        >
        <input
          class="px-3 py-2 bg-yellow-500 text-black block mt-2 w-40 rounded-md text-sm"
          value="Update post"
          type="submit"
        />
      </form>
    </div>
  </body>
</html>
